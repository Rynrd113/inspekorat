<IfModule mod_rewrite.c>
    RewriteEngine On
    
    # Pass through actual files and directories
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]
    
    # Rewrite everything else to public/
    RewriteRule ^(.*)$ public/$1 [L]
</IfModule>

# Prevent access to .env
<Files .env>
    Order allow,deny
    Deny from all
</Files>
